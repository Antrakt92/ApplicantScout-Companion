# Developer/backcompat config. Normal installed users should use the companion
# first-run/settings UI, which writes:
# %LOCALAPPDATA%\applicant-scout\config\config.env
#
# Get these from https://www.warcraftlogs.com/api/clients/
# Create a client (any name, any redirect URL like http://localhost, NOT public).
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# Optional overrides
# Primary transport folder override. Must be the active WoW retail Screenshots
# folder under _retail_; arbitrary folders are rejected because the addon writes
# transport snapshots through WoW's screenshot system.
# APSCOUT_SCREENSHOTS_PATH=C:\Games\World of Warcraft\_retail_\Screenshots

# Startup fallback only; live snapshots from the addon normally provide region.
# APSCOUT_REGION=EU

# Optional WCL character cache TTL in seconds. Blank/unset keeps the 12-hour
# default.
# APSCOUT_CACHE_TTL_SECONDS=43200

# Legacy path fallback. If APSCOUT_SCREENSHOTS_PATH is unset, the companion can
# derive _retail_\Screenshots from this old Logs path setting.
# APSCOUT_CHATLOG_PATH=C:\Games\World of Warcraft\_retail_\Logs\WoWChatLog.txt
